{
  "expo": {
    "name": "Mixterious",
    "description": "It's karaoke time!",
    "slug": "karaoapp",
    "version": "1.0",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "icon": "./ios/Mixterious/Images.xcassets/AppIcon.appiconset/AppIcon.png",
    "splash": {
      "image": "./ios/Mixterious/Images.xcassets/SplashScreen.imageset/SplashScreen.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cazares.mixterious",
      "buildNumber": "112",
      "infoPlist": {
        "NSPhotoLibraryAddUsageDescription": "Mixterious saves karaoke videos you create to your Photos library when you tap Save.",
        "NSUserNotificationsUsageDescription": "Mixterious can send optional notifications when background karaoke processing finishes, if you enable Background Notifications."
      }
    },
    "android": {
      "package": "com.cazares.mixterious",
      "versionCode": 112
    },
    "notification": {
      "icon": "./icons/notification-icon.png",
      "color": "#4a90e2"
    },
    "extra": {
      "privacyPolicyUrl": "https://mixterious.co/privacy",
      "termsOfUseUrl": "https://mixterious.co/terms",
      "supportUrl": "https://mixterious.co/support",
      "eas": {
        "projectId": "8f4aeff3-940f-4ec2-b82d-89b430f5c8be"
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./icons/notification-icon.png",
          "color": "#4a90e2",
          "sounds": []
        }
      ]
    ]
  }
}
