#!/usr/bin/env bash
set -euo pipefail

wall_start="${EPOCHREALTIME:-}"
if [ -z "$wall_start" ]; then
  wall_start="$(
    python3 - <<'PY'
import time
print(f"{time.perf_counter():.6f}")
PY
  )"
fi

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
ROOT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

cd "$ROOT_DIR"

show_help=0
no_open=0
pipeline_args=()
for arg in "$@"; do
  case "$arg" in
    -h|--help)
      show_help=1
      pipeline_args+=("$arg")
      ;;
    --no-open)
      no_open=1
      ;;
    *)
      pipeline_args+=("$arg")
      ;;
  esac
done

if [ "${MIX_NO_OPEN:-}" != "" ]; then
  case "$(printf '%s' "${MIX_NO_OPEN}" | tr '[:upper:]' '[:lower:]')" in
    1|true|yes|on)
      no_open=1
      ;;
  esac
fi

auto_open_enabled=1
if [ "${MIX_AUTO_OPEN:-}" != "" ]; then
  case "$(printf '%s' "${MIX_AUTO_OPEN}" | tr '[:upper:]' '[:lower:]')" in
    0|false|no|off)
      auto_open_enabled=0
      ;;
  esac
fi

auto_open_cooldown_sec="${MIX_AUTO_OPEN_COOLDOWN_SEC:-8}"
case "$auto_open_cooldown_sec" in
  ''|*[!0-9]*)
    auto_open_cooldown_sec=8
    ;;
esac

tmp_log="$(
  mktemp -t mix-run.XXXXXX.log 2>/dev/null \
    || mktemp "${TMPDIR:-/tmp}/mix-run.XXXXXX.log"
)"

emit_wall_total() {
  local wall_end elapsed
  wall_end="${EPOCHREALTIME:-}"
  if [ -z "$wall_end" ]; then
    wall_end="$(
      python3 - <<'PY'
import time
print(f"{time.perf_counter():.6f}")
PY
    )"
  fi
  elapsed="$(
    python3 - "$wall_start" "$wall_end" <<'PY'
import sys
start = float(sys.argv[1])
end = float(sys.argv[2])
print(f"{max(0.0, end - start):.3f}")
PY
  )"
  printf '[MIX] wall_total_seconds=%s\n' "$elapsed"
}

open_and_play_video() {
  local output_path="$1"
  # Poll briefly so Finder/QuickTime does not race a just-finalized file.
  local tries=0
  local last_size=-1
  local stable_hits=0
  while [ "$tries" -lt 35 ]; do
    if [ -f "$output_path" ]; then
      local sz
      sz="$(wc -c < "$output_path" 2>/dev/null || printf '0')"
      case "$sz" in
        ''|*[!0-9]*)
          sz=0
          ;;
      esac
      if [ "$sz" -gt 0 ]; then
        if [ "$sz" -eq "$last_size" ]; then
          stable_hits=$((stable_hits + 1))
        else
          stable_hits=0
        fi
        last_size="$sz"
        if [ "$stable_hits" -ge 1 ]; then
          break
        fi
      fi
    fi
    sleep 0.12
    tries=$((tries + 1))
  done
  sleep 0.25

  if command -v osascript >/dev/null 2>&1; then
    if osascript - "$output_path" >/dev/null 2>&1 <<'APPLESCRIPT'; then
on run argv
  set videoFile to POSIX file (item 1 of argv)
  tell application "QuickTime Player"
    activate
    close every document saving no
    set openedDoc to open videoFile
    delay 0.15
    play openedDoc
  end tell
end run
APPLESCRIPT
      printf '[MIX] autoplay=quicktime path=%s\n' "$output_path"
      return 0
    fi
  fi
  open "$output_path" >/dev/null 2>&1 || true
  printf '[MIX] autoplay=fallback-open path=%s\n' "$output_path"
}

cleanup() {
  rm -f "$tmp_log"
}
trap cleanup EXIT

should_auto_open() {
  if [ "$show_help" -ne 0 ]; then
    printf '[MIX] auto-open=skipped reason=help\n'
    return 1
  fi
  if [ "$no_open" -ne 0 ]; then
    printf '[MIX] auto-open=skipped reason=disabled\n'
    return 1
  fi
  if [ "$auto_open_enabled" -eq 0 ]; then
    printf '[MIX] auto-open=skipped reason=env-disabled\n'
    return 1
  fi
  if [ ! -t 0 ] || [ ! -t 1 ]; then
    printf '[MIX] auto-open=skipped reason=non-interactive\n'
    return 1
  fi
  if ! command -v open >/dev/null 2>&1; then
    printf '[MIX] auto-open=skipped reason=no-open-cmd\n'
    return 1
  fi

  local stamp_path now_epoch last_epoch
  stamp_path="${TMPDIR:-/tmp}/mix-auto-open.last"
  now_epoch="$(date +%s)"
  if [ -f "$stamp_path" ]; then
    last_epoch="$(cat "$stamp_path" 2>/dev/null || printf '0')"
    case "$last_epoch" in
      ''|*[!0-9]*)
        last_epoch=0
        ;;
    esac
    if [ "$auto_open_cooldown_sec" -gt 0 ] && [ $((now_epoch - last_epoch)) -lt "$auto_open_cooldown_sec" ]; then
      printf '[MIX] auto-open=skipped reason=cooldown remaining=%ss\n' "$((auto_open_cooldown_sec - (now_epoch - last_epoch)))"
      return 1
    fi
  fi
  printf '%s\n' "$now_epoch" > "$stamp_path" 2>/dev/null || true
  return 0
}

main_cmd=(python3 -m scripts.main --open-disabled)
if [ "${#pipeline_args[@]}" -gt 0 ]; then
  main_cmd+=("${pipeline_args[@]}")
fi

if "${main_cmd[@]}" 2>&1 | tee "$tmp_log"; then
  emit_wall_total
  if should_auto_open; then
    output_path="$(
      sed -E $'s/\x1B\\[[0-9;]*[A-Za-z]//g' "$tmp_log" \
        | awk -F'Output: ' '/Output: / {print $2}' \
        | tail -n1 \
        | tr -d '\r'
    )"
    if [ -n "$output_path" ] && [[ "$output_path" != /* ]]; then
      output_path="$ROOT_DIR/output/$output_path"
    fi
    if [ -n "$output_path" ] && [ -f "$output_path" ]; then
      if [ -d "$ROOT_DIR/output" ]; then
        open "$ROOT_DIR/output" >/dev/null 2>&1 || true
        printf '[MIX] open-dir=%s\n' "$ROOT_DIR/output"
      fi
      open_and_play_video "$output_path"
    elif [ -d "$ROOT_DIR/output" ]; then
      open "$ROOT_DIR/output" >/dev/null 2>&1 || true
      printf '[MIX] open-dir=%s\n' "$ROOT_DIR/output"
    fi
  fi
  exit 0
fi

rc=$?
emit_wall_total
exit "$rc"
