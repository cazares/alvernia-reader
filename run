#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
ROOT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

cd "$ROOT_DIR"

args=("$@")

has_query_flag=0
has_speed_mode=0
has_yt_search_n=0

for ((i = 0; i < ${#args[@]}; i++)); do
  arg="${args[i]}"
  case "$arg" in
    --query)
      has_query_flag=1
      ((i++))
      ;;
    --query=*)
      has_query_flag=1
      ;;
    --speed-mode)
      has_speed_mode=1
      ((i++))
      ;;
    --speed-mode=*)
      has_speed_mode=1
      ;;
    --yt-search-n)
      has_yt_search_n=1
      ((i++))
      ;;
    --yt-search-n=*)
      has_yt_search_n=1
      ;;
  esac
done

cmd=("$ROOT_DIR/mix")

if [ "$has_yt_search_n" -eq 0 ]; then
  cmd+=(--yt-search-n 3)
fi

if [ "$has_speed_mode" -eq 0 ]; then
  cmd+=(--speed-mode extra-turbo)
fi

if [ "$has_query_flag" -eq 0 ] && [ "${#args[@]}" -gt 0 ] && [[ "${args[0]}" != -* ]]; then
  cmd+=(--query "${args[0]}")
  if [ "${#args[@]}" -gt 1 ]; then
    cmd+=("${args[@]:1}")
  fi
else
  cmd+=("${args[@]}")
fi

exec "${cmd[@]}"
