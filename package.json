{
  "name": "alvernia-reader",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "ios:local": "bash ./scripts/start-ios-simulator-local.sh",
    "android": "expo run:android",
    "build:web": "node ./web/build.mjs",
    "upload:server": "node ./scripts/upload-server.mjs",
    "promote:watch": "node ./scripts/keynote-promote.mjs",
