# Expo public env vars
# Set this to your API base URL. Examples:
# EXPO_PUBLIC_API_BASE_URL=https://karaoapi-ujhkqz2naa-uc.a.run.app
# EXPO_PUBLIC_API_BASE_URL=https://api.miguelscode.com
EXPO_PUBLIC_API_BASE_URL=https://karaoapi-ujhkqz2naa-uc.a.run.app

# EAS OTA / "CodePush"-style update settings
# Obtain this once with: npx eas project:init
# Then keep it stable for all builds/updates.
EXPO_PUBLIC_EAS_PROJECT_ID=
# Required for EAS preview/production builds (app.config enforces this).

# Optional channel label surfaced in runtime config.
# Build profiles still define true rollout channels in eas.json.
EXPO_PUBLIC_OTA_CHANNEL=production

# Set to 0 to disable OTA checks in a local/dev environment.
EXPO_PUBLIC_OTA_ENABLED=1

# Set to 0 to disable automatic OTA checks on app launch/foreground.
EXPO_PUBLIC_OTA_AUTO_CHECK=1
