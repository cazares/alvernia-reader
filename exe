#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
ROOT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

cd "$ROOT_DIR"

is_numeric() {
  local value="${1:-}"
  [[ "$value" =~ ^[+-]?([0-9]+([.][0-9]*)?|[.][0-9]+)$ ]]
}

args=("$@")
has_offset_flag=0

for ((i = 0; i < ${#args[@]}; i++)); do
  arg="${args[i]}"
  case "$arg" in
    --off|--offset)
      has_offset_flag=1
      ((i++))
      ;;
    --off=*|--offset=*)
      has_offset_flag=1
      ;;
  esac
done

run_cmd=("$ROOT_DIR/run")

if [ "$has_offset_flag" -eq 0 ] && [ "${#args[@]}" -ge 2 ]; then
  first="${args[0]}"
  second="${args[1]}"
  if is_numeric "$first" && ! is_numeric "$second"; then
    run_cmd+=(--query "$second" --off "$first" "${args[@]:2}")
  elif ! is_numeric "$first" && is_numeric "$second"; then
    run_cmd+=(--query "$first" --off "$second" "${args[@]:2}")
  else
    run_cmd+=("${args[@]}")
  fi
else
  run_cmd+=("${args[@]}")
fi

if MIX_NO_OPEN=1 "${run_cmd[@]}"; then
  rc=0
else
  rc=$?
fi

if [ "$rc" -eq 0 ] && [ -t 0 ] && [ -t 1 ] && command -v open >/dev/null 2>&1; then
  if [ -d "$ROOT_DIR/output" ]; then
    open "$ROOT_DIR/output" >/dev/null 2>&1 || true
    printf '[EXE] open-dir=%s\n' "$ROOT_DIR/output"
  fi
fi

exit "$rc"
